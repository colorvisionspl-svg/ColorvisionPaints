@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Login";
    var mode = ViewBag.Mode ?? "phone";
    var otpSent = ViewBag.OtpSent == true;
}

<div class="login-card">
    <!-- Branding -->
    <div class="login-brand">
        <div class="login-logo">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
        </div>
        <h1>ColorVision Paints</h1>
        <p>Enterprise Resource Planning</p>
    </div>

    <!-- Mode Toggle -->
    <div class="login-toggle">
        <a href="/Auth/Login?mode=phone" class="login-toggle-btn @(mode == "phone" ? "active" : "")" id="toggle-phone">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
            Phone OTP
        </a>
        <a href="/Auth/Login?mode=email" class="login-toggle-btn @(mode == "email" ? "active" : "")" id="toggle-email">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            Email Login
        </a>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="login-error visible" id="login-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
            <span class="error-text">@ViewBag.Error</span>
        </div>
    }

    <!-- ═══ PHONE OTP FORM ═══ -->
    @if (mode == "phone")
    {
        @if (!otpSent)
        {
            <form action="/Auth/SendOtp" method="post" class="login-form" id="phone-form">
                <div class="form-group">
                    <label for="PhoneNumber">Mobile Number</label>
                    <div class="phone-input-group">
                        <div class="phone-prefix">+91</div>
                        <input type="tel" class="login-input" id="PhoneNumber" name="PhoneNumber" placeholder="Enter 10-digit mobile number" maxlength="10" required />
                    </div>
                </div>
                <button type="submit" class="login-submit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                    Send OTP
                </button>
            </form>
        }
        else
        {
            <div class="phone-sent-info" style="display: flex;">
                <span>+91 @ViewBag.PhoneNumber</span>
                <a href="/Auth/Login?mode=phone" style="margin-left:auto; font-size:12px; color:var(--color-primary-main)">Change</a>
            </div>

            <form action="/Auth/VerifyOtp" method="post" class="login-form">
                <input type="hidden" name="SessionInfo" value="@ViewBag.SessionInfo" />
                <input type="hidden" name="PhoneNumber" value="@ViewBag.PhoneNumber" />

                <div class="otp-section visible">
                    <div class="otp-label-row">
                        <label>Enter 6-digit OTP</label>
                    </div>
                    <div class="form-group">
                        <!-- Simplified single input for MVC form (you could keep 6 and map in JS, but 1 is simpler for standard forms) -->
                        <input type="text" class="login-input" name="Code" maxlength="6" pattern="\d{6}" placeholder="------" style="text-align:center; font-size: 24px; letter-spacing: 12px;" required />
                    </div>
                </div>

                <button type="submit" class="login-submit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    Verify & Login
                </button>
            </form>
        }
    }

    <!-- ═══ EMAIL LOGIN FORM ═══ -->
    @if (mode == "email")
    {
        <form action="/Auth/EmailLogin" method="post" class="login-form" id="email-form">
            <div class="form-group">
                <label for="Email">Email Address</label>
                <input type="email" class="login-input" id="Email" name="Email" placeholder="admin@colorvision.com" required />
            </div>

            <div class="form-group">
                <label for="Password">Password</label>
                <input type="password" class="login-input" id="Password" name="Password" placeholder="Enter your password" required />
            </div>

            <button type="submit" class="login-submit">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Login
            </button>
        </form>
    }

    <!-- Footer -->
    <div class="login-footer">
        <p>© 2026 ColorVision Paints Pvt. Ltd. · Powered by Nexus ERP</p>
    </div>
</div>
