@page
@{
    Layout = "_AppShell";
    ViewData["Title"] = "Sales Dashboard";
}

<div class="page-header">
    <h1>Sales Dashboard</h1>
    <div class="page-header-actions">
        <button class="btn-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            This Month
        </button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Monthly Target</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-blue);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <div class="kpi-card-value">₹15,00,000</div>
        <div class="kpi-card-sub">72% achieved</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Orders Today</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-indigo);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <div class="kpi-card-value">28</div>
        <div class="kpi-card-sub">+5 from yesterday</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Active Reps</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-teal);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <div class="kpi-card-value">14</div>
        <div class="kpi-card-sub">2 inactive today</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Pending Approvals</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-pink);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="kpi-card-value">7</div>
        <div class="kpi-card-sub" style="color: var(--color-warning);">Action required</div>
    </div>
</div>

<div class="card" style="min-height: 200px;">
    <h3 style="margin-bottom: var(--space-4);">Sales Team Performance</h3>
    <p class="text-muted">Detailed sales analytics will be added in the next phase.</p>
</div>
