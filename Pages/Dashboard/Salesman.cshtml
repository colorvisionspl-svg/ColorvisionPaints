@page
@{
    Layout = "_AppShell";
    ViewData["Title"] = "My Dashboard";
}

<div class="page-header">
    <h1>My Dashboard</h1>
    <div class="page-header-actions">
        <button class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Order
        </button>
    </div>
</div>

<div class="kpi-grid" style="grid-template-columns: repeat(2, 1fr);">
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Today's Target</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-blue);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <div class="kpi-card-value">₹50,000</div>
        <div class="kpi-card-sub">₹32,500 achieved (65%)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Visits Today</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-teal);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="kpi-card-value">6 / 10</div>
        <div class="kpi-card-sub">4 remaining</div>
    </div>
</div>

<div class="card" style="min-height: 200px;">
    <h3 style="margin-bottom: var(--space-4);">Today's Visit Schedule</h3>
    <p class="text-muted">Visit tracking and route planning will be added in the next phase.</p>
</div>
