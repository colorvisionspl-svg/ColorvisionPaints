@page
@{
    Layout = "_AppShell";
    ViewData["Title"] = "Warehouse Dashboard";
}

<div class="page-header">
    <h1>Warehouse Dashboard</h1>
    <div class="page-header-actions">
        <button class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            New Dispatch
        </button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Total SKUs</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-blue);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        </div>
        <div class="kpi-card-value">542</div>
        <div class="kpi-card-sub">28 low stock</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Pending Dispatches</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-indigo);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="kpi-card-value">18</div>
        <div class="kpi-card-sub" style="color: var(--color-warning);">5 overdue</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Received Today</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-teal);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
        </div>
        <div class="kpi-card-value">120</div>
        <div class="kpi-card-sub">Units received</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <span class="kpi-card-label">Stock Value</span>
            <svg class="kpi-card-icon" style="color: var(--color-icon-pink);" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="kpi-card-value">₹85,40,000</div>
        <div class="kpi-card-sub">Across all warehouses</div>
    </div>
</div>

<div class="card" style="min-height: 200px;">
    <h3 style="margin-bottom: var(--space-4);">Inventory Status</h3>
    <p class="text-muted">Inventory management details will be added in the next phase.</p>
</div>
