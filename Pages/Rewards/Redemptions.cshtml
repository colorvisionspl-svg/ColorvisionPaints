@page
@model ColorvisionPaintsERP.Pages.Rewards.RedemptionsModel
@{
    Layout = "_AppShell";
    ViewData["Title"] = "Redemptions";
    var pending    = Model.Txns.Count(t => t.Status == "Pending");
    var processing = Model.Txns.Count(t => t.Status == "Processing");
    var totalAmt   = Model.Txns.Where(t => t.Status == "Completed").Sum(t => t.Amount);
    var tdsTotal   = Model.Txns.Sum(t => t.TdsDeducted);
}
@section PageStyles {
    <link rel="stylesheet" href="~/css/procurement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/rewards.css" asp-append-version="true" />
}

<div class="page-container">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Redemptions</h1>
            <p class="page-subtitle">Process UPI payout requests from painters. TDS automatically flagged at ₹20,000+</p>
        </div>
        <button class="btn-primary" onclick="bulkApprove()">
            Bulk Approve Selected
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="procurement-summary-row">
        <div class="glass-card summary-card">
            <p class="label">Pending Requests</p>
            <p class="value" style="color:#F7A24F">@pending</p>
        </div>
        <div class="glass-card summary-card">
            <p class="label">Processing</p>
            <p class="value" style="color:#4F6EF7">@processing</p>
        </div>
        <div class="glass-card summary-card">
            <p class="label">Paid Out (All Time)</p>
            <p class="value" style="color:#22C997">₹@totalAmt.ToString("N0")</p>
        </div>
        <div class="glass-card summary-card">
            <p class="label">TDS Collected</p>
            <p class="value" style="color:#7C6FF7">₹@tdsTotal.ToString("N0")</p>
        </div>
    </div>

    @if (tdsTotal > 0)
    {
        <div class="glass-card" style="padding:14px 18px;border-left:3px solid #F7A24F;background:rgba(247,162,79,0.05);margin-bottom:20px;display:flex;align-items:center;gap:12px">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F7A24F" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p style="font-size:13px;color:var(--color-text-primary);margin:0">TDS of ₹@tdsTotal.ToString("N0") has been auto-deducted (10%) from painters whose annual rewards exceeded ₹20,000. Form 16A will be generated at year-end.</p>
        </div>
    }

    <!-- Table -->
    <div class="glass-card table-wrapper">
        <div class="filter-bar">
            <div class="search-group">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" placeholder="Search painter, UPI…" oninput="RewardsUI.filterTable('redemption-table', this.value)">
            </div>
            <select class="filter-select">
                <option value="">All Status</option>
                <option>Pending</option>
                <option>Processing</option>
                <option>Completed</option>
                <option>Failed</option>
            </select>
        </div>
        <table class="data-table" id="redemption-table">
            <thead>
                <tr>
                    <th><input type="checkbox" id="sel-all-redeem" onchange="RewardsUI.toggleSelectAll('sel-all-redeem','redeem-check')"></th>
                    <th>Painter</th>
                    <th>Points</th>
                    <th>Amount ₹</th>
                    <th>TDS</th>
                    <th>Type</th>
                    <th>UPI ID</th>
                    <th>UPI Ref</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Txns)
                {
                    var statusCls = t.Status switch {
                        "Pending"    => "status-planned",
                        "Processing" => "status-released",
                        "Completed"  => "status-active",
                        "Failed"     => "status-failed",
                        _            => "status-draft"
                    };
                    <tr>
                        <td><input type="checkbox" class="redeem-check" onchange="RewardsUI.updateBulkBar()"></td>
                        <td><span class="bold">@t.PainterName</span></td>
                        <td style="font-weight:700">@t.Points.ToString("N0")</td>
                        <td style="font-weight:700;color:#22C997">₹@t.Amount.ToString("N0")</td>
                        <td>
                            @if (t.TdsDeducted > 0)
                            {
                                <span style="color:#F7A24F;font-weight:700;font-size:12px">−₹@t.TdsDeducted.ToString("N0")</span>
                            }
                            else { <span style="color:var(--color-text-muted);font-size:12px">Nil</span> }
                        </td>
                        <td>@t.RedemptionType</td>
                        <td style="font-family:monospace;font-size:12px">@t.UpiId</td>
                        <td style="font-family:monospace;font-size:11px">@(string.IsNullOrEmpty(t.UpiTransactionId) ? "—" : t.UpiTransactionId)</td>
                        <td><span class="status-pill @statusCls">@t.Status</span></td>
                        <td>@t.CreatedAt.ToString("dd MMM HH:mm")</td>
                        <td class="actions-cell">
                            @if (t.Status == "Pending")
                            {
                                <button class="btn-primary" style="height:28px;font-size:11px;padding:0 10px" onclick="approveOne('@t.Id','@t.PainterName',@t.Amount)">Approve</button>
                            }
                            @if (t.Status is "Pending" or "Processing")
                            {
                                <button class="btn-icon" title="Mark Failed" onclick="markFailed('@t.Id')">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#F76F6F" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section PageScripts {
    <script src="~/js/rewards-admin.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => RewardsUI.initClosers());

        function approveOne(id, name, amount) {
            if (confirm(`Approve ₹${amount} redemption for ${name}?\nThis will initiate UPI transfer.`)) {
                alert(`✅ Redemption approved! UPI transfer of ₹${amount} to ${name} initiated. Ref will appear in 30 mins.`);
            }
        }

        function markFailed(id) {
            const reason = prompt('Reason for failure:');
            if (reason) alert('Redemption marked as Failed.');
        }

        function bulkApprove() {
            const selected = document.querySelectorAll('.redeem-check:checked').length;
            if (!selected) { alert('Select at least one redemption to bulk approve.'); return; }
            if (confirm(`Approve ${selected} redemption(s)? UPI transfers will be initiated.`)) {
                alert(`✅ ${selected} redemption(s) approved!`);
            }
        }
    </script>
}
