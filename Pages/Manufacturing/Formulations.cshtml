@page
@model ColorvisionPaintsERP.Pages.Manufacturing.FormulationsModel
@{
    Layout = "_AppShell";
    ViewData["Title"] = "Formulations";
    var totalForms   = Model.Formulations.Count;
    var activeForms  = Model.Formulations.Count(f => f.Status == "Active");
    var draftForms   = Model.Formulations.Count(f => f.Status == "Draft");
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/procurement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/manufacturing.css" asp-append-version="true" />
}

<div class="page-container">

    <!-- Header -->
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Formulations</h1>
            <p class="page-subtitle">Define and manage paint formulation recipes with ingredients & process steps</p>
        </div>
        <div class="actions">
            <button class="btn-ghost" id="btn-filter-forms">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                Filter
            </button>
            <button class="btn-primary" id="btn-add-formulation" onclick="MfgUI.openPanel('panel-formulation')">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New Formulation
            </button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="procurement-summary-row">
        <div class="glass-card summary-card">
            <p class="label">Total Formulations</p>
            <p class="value">@totalForms</p>
        </div>
        <div class="glass-card summary-card">
            <p class="label">Active</p>
            <p class="value" style="color:#22C997">@activeForms</p>
        </div>
        <div class="glass-card summary-card">
            <p class="label">Draft / Pending</p>
            <p class="value" style="color:#F7A24F">@draftForms</p>
        </div>
    </div>

    <!-- Table -->
    <div class="glass-card table-wrapper">
        <div class="filter-bar">
            <div class="search-group">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="form-search" placeholder="Search formulation…" oninput="filterForms(this.value)">
            </div>
            <select class="filter-select" id="form-status-filter" onchange="filterForms()">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Draft">Draft</option>
                <option value="Archived">Archived</option>
            </select>
        </div>

        <table class="data-table" id="form-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Product</th>
                    <th>Shade</th>
                    <th>Ver.</th>
                    <th>Batch Size</th>
                    <th>Yield %</th>
                    <th>Process Time</th>
                    <th>Ingredients</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Formulations)
                {
                    var statusCls = f.Status switch {
                        "Active"   => "status-active",
                        "Draft"    => "status-draft",
                        "Archived" => "status-archived",
                        _          => "status-draft"
                    };
                    <tr>
                        <td><span class="material-pill">@f.FormulationCode</span></td>
                        <td><span class="bold">@f.ProductName</span></td>
                        <td>@f.ShadeName</td>
                        <td style="text-align:center">v@f.Version</td>
                        <td>@f.StandardBatchSizeKg.ToString("N0") kg</td>
                        <td>@f.ExpectedYieldPercent.ToString("F1")%</td>
                        <td>@f.ProcessingTimeHours h</td>
                        <td style="text-align:center">@f.Ingredients.Count items</td>
                        <td><span class="status-pill @statusCls">@f.Status</span></td>
                        <td class="actions-cell">
                            <button class="btn-icon" title="View" onclick="openFormulationDetail('@f.Id')">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                            <button class="btn-icon" title="Edit" onclick="MfgUI.openPanel('panel-formulation')">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </button>
                            <button class="btn-icon" title="Duplicate">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ── PANEL OVERLAY ── -->
<div class="panel-overlay" id="panel-overlay" onclick="MfgUI.closeAllPanels()"></div>

<!-- ── SLIDE PANEL: CREATE/EDIT FORMULATION ── -->
<div class="slide-panel" id="panel-formulation" style="width:620px">
    <div class="slide-panel-header">
        <h2>New Formulation</h2>
        <button class="close-panel-btn" onclick="MfgUI.closeAllPanels()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>
    <div class="slide-panel-content">

        <!-- Section 1: Basic Info -->
        <p class="panel-section-title" style="margin-top:0">Basic Information</p>
        <div class="form-grid">
            <div class="form-group">
                <label>Product *</label>
                <select class="form-control" id="form-product">
                    <option value="">Select product…</option>
                    <option value="P1">InteriorEmu Pro</option>
                    <option value="P2">Exterior Shield XT</option>
                    <option value="P3">Steel Coat Pro</option>
                </select>
            </div>
            <div class="form-group">
                <label>Shade *</label>
                <select class="form-control" id="form-shade">
                    <option value="">Select shade…</option>
                    <option value="S1">Arctic White</option>
                    <option value="S2">Ocean Blue</option>
                    <option value="S3">Silver Grey</option>
                </select>
            </div>
            <div class="form-group">
                <label>Batch Size (kg) *</label>
                <input type="number" class="form-control" id="form-batch-size" value="1000"
                       oninput="MfgUI.setBatchSize(this.value)">
            </div>
            <div class="form-group">
                <label>Expected Yield %</label>
                <input type="number" class="form-control" id="form-yield" value="96" step="0.1">
            </div>
            <div class="form-group">
                <label>Processing Time (hrs)</label>
                <input type="number" class="form-control" id="form-proc-time" step="0.5">
            </div>
            <div class="form-group">
                <label>Status</label>
                <select class="form-control" id="form-status">
                    <option value="Draft">Draft</option>
                    <option value="Active">Active</option>
                </select>
            </div>
        </div>

        <!-- Section 2: Ingredients -->
        <div style="margin-top:20px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                <p class="panel-section-title" style="margin:0">Ingredients</p>
                <button type="button" class="btn-ghost" style="height:32px;padding:0 12px;font-size:12px"
                        onclick="MfgUI.addIngredientRow([])">
                    + Add Ingredient
                </button>
            </div>
            <div style="overflow-x:auto">
                <table class="ingredient-table">
                    <thead>
                        <tr>
                            <th style="width:140px">Material</th>
                            <th style="width:40px">Seq</th>
                            <th style="width:80px">Qty (kg)</th>
                            <th style="width:60px">% Wt</th>
                            <th style="width:50px">Tol−</th>
                            <th style="width:50px">Tol+</th>
                            <th style="width:40px">Unit</th>
                            <th style="width:80px">Notes</th>
                            <th style="width:30px"></th>
                        </tr>
                    </thead>
                    <tbody id="ingredient-tbody">
                        <!-- rows injected by JS -->
                    </tbody>
                </table>
            </div>
            <div class="pct-total-row" id="ing-pct-total">0.00%</div>
        </div>

        <!-- Section 3: Process Steps -->
        <div style="margin-top:20px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                <p class="panel-section-title" style="margin:0">Process Steps</p>
                <button type="button" class="btn-ghost" style="height:32px;padding:0 12px;font-size:12px"
                        onclick="MfgUI.addProcessStep()">
                    + Add Step
                </button>
            </div>
            <div style="overflow-x:auto">
                <table class="step-table">
                    <thead>
                        <tr>
                            <th style="width:28px"></th>
                            <th style="width:36px">#</th>
                            <th style="width:110px">Title</th>
                            <th>Instruction</th>
                            <th style="width:55px">Min</th>
                            <th style="width:70px">Temp °C</th>
                            <th style="width:90px">Equipment</th>
                            <th style="width:28px"></th>
                        </tr>
                    </thead>
                    <tbody id="step-tbody"></tbody>
                </table>
            </div>
        </div>

    </div>
    <div class="slide-panel-footer">
        <button class="btn-ghost" onclick="MfgUI.closeAllPanels()">Cancel</button>
        <button class="btn-primary" style="background:rgba(79,110,247,0.2);color:#4F6EF7" onclick="saveFormulationDraft()">Save Draft</button>
        <button class="btn-primary" id="submit-formulation-btn" onclick="submitFormulation()">Submit for Approval</button>
    </div>
</div>

@section PageScripts {
    <script src="~/js/manufacturing.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            MfgUI.initPanelClosers();
        });

        function filterForms(val) {
            const q = (val || document.getElementById('form-search')?.value || '').toLowerCase();
            const status = document.getElementById('form-status-filter')?.value || '';
            document.querySelectorAll('#form-table tbody tr').forEach(tr => {
                const text = tr.textContent.toLowerCase();
                const statusMatch = !status || text.includes(status.toLowerCase());
                tr.style.display = (text.includes(q) && statusMatch) ? '' : 'none';
            });
        }

        function openFormulationDetail(id) {
            // TODO: open detail modal
        }

        function saveFormulationDraft() {
            alert('Draft saved successfully!');
            MfgUI.closeAllPanels();
        }

        function submitFormulation() {
            const totalEl = document.getElementById('ing-pct-total');
            if (totalEl && totalEl.classList.contains('pct-total-bad')) {
                alert('Ingredient percentages must sum to 100% before submitting.');
                return;
            }
            alert('Formulation submitted for approval!');
            MfgUI.closeAllPanels();
        }
    </script>
}
