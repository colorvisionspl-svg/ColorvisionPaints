@page
@model ColorvisionPaintsERP.Pages.Procurement.PurchaseOrdersModel
@{
    ViewData["Title"] = "Purchase Orders";
    Layout = "_AppShell";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/procurement.css" />
    <style>
        .items-badge {
            background: rgba(0,0,0,0.05);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
        }
        .total-amount-row {
            display: flex;
            justify-content: flex-end;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1.5px solid rgba(0,0,0,0.05);
        }
        .total-item {
            text-align: right;
            margin-left: 24px;
        }
        .total-item .label { font-size: 12px; color: var(--color-text-muted); }
        .total-item .value { font-size: 14px; font-weight: 700; color: var(--color-text-primary); }
        .total-item.grand .value { font-size: 18px; color: var(--color-accent); }
    </style>
}

<div class="page-container">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Purchase Orders</h1>
            <p class="page-subtitle">Draft and manage procurement orders for raw materials</p>
        </div>
        <button class="btn-primary" onclick="ProcurementUI.openPanel('create-po-panel')">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7v14"/></svg>
            Create PO
        </button>
    </div>

    <!-- Summary Row -->
    <div class="procurement-summary-row">
        <div class="glass-card summary-card">
            <div class="label">Total POs (MTD)</div>
            <div class="value">@Model.Orders.Count</div>
        </div>
        <div class="glass-card summary-card">
            <div class="label">Pending Delivery</div>
            <div class="value" style="color:#F7A24F">@Model.Orders.Count(o => o.Status == "Sent" || o.Status == "Partial")</div>
        </div>
        <div class="glass-card summary-card">
            <div class="label">Total Value MTD</div>
            <div class="value">₹@Model.Orders.Sum(o => o.TotalAmount).ToString("N0")</div>
        </div>
        <div class="glass-card summary-card">
            <div class="label">Overdue POs</div>
            <div class="value" style="color:#F76F6F">0</div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card filter-bar">
        <div class="search-group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" placeholder="PO # or Vendor..." id="po-search">
        </div>
        <select class="filter-select">
            <option>All Status</option>
            <option>Draft</option>
            <option>Sent</option>
            <option>Partial</option>
            <option>Received</option>
        </select>
        <input type="date" class="filter-select" title="From Date">
        <input type="date" class="filter-select" title="To Date">
    </div>

    <!-- PO Table -->
    <div class="glass-card table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>PO Number</th>
                    <th>Vendor</th>
                    <th>Order Date</th>
                    <th>Expected Delivery</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var po in Model.Orders)
                {
                    <tr>
                        <td class="bold">@po.PoNumber</td>
                        <td>@po.VendorName</td>
                        <td>@po.OrderDate.ToString("dd MMM yyyy")</td>
                        <td>@po.ExpectedDeliveryDate.ToString("dd MMM yyyy")</td>
                        <td><span class="items-badge">@po.Items.Count Items</span></td>
                        <td class="bold">₹@po.TotalAmount.ToString("N0")</td>
                        <td>
                            <span class="status-pill status-@(po.Status.ToLower())">@po.Status</span>
                        </td>
                        <td style="text-align:right">
                            <div class="actions-cell">
                                <button class="btn-icon" title="View"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                <button class="btn-icon" title="Edit"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- CREATE PO SLIDE PANEL -->
<div class="slide-panel" id="create-po-panel">
    <div class="slide-panel-header">
        <h2>Create Purchase Order</h2>
        <button class="close-panel-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
    </div>
    <div class="slide-panel-content">
        <form id="po-form">
            <div class="panel-section-title">Vendor & Logistics</div>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>Select Vendor</label>
                    <select class="form-control" name="VendorId" required id="po-vendor-select">
                        <option value="">Choose a vendor...</option>
                        @foreach(var v in Model.Vendors) {
                            <option value="@v.Id">@v.CompanyName (@v.QualityRating ★)</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Order Date</label>
                    <input type="date" class="form-control" name="OrderDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="form-group">
                    <label>Expected Delivery</label>
                    <input type="date" class="form-control" name="ExpectedDeliveryDate">
                </div>
                <div class="form-group full-width">
                    <label>Notes / Special Instructions</label>
                    <textarea class="form-control" name="Notes" style="height:60px"></textarea>
                </div>
            </div>

            <div class="panel-section-title" style="margin-top:24px">Order Items</div>
            <div style="overflow-x:auto">
                <table class="item-table" id="po-items-table">
                    <thead>
                        <tr>
                            <th>Material</th>
                            <th width="80">Qty</th>
                            <th width="100">Rate (₹)</th>
                            <th width="60">Tax%</th>
                            <th width="100">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Rows added via JS -->
                    </tbody>
                </table>
            </div>
            <button type="button" class="btn-ghost" style="margin-top:12px; font-size:12px;" onclick="addPoRow()">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><path d="M5 12h14m-7-7v14"/></svg>
                Add Item
            </button>

            <div class="total-amount-row">
                <div class="total-item">
                    <div class="label">Subtotal</div>
                    <div class="value" id="po-subtotal">₹0</div>
                </div>
                <div class="total-item">
                    <div class="label">Tax</div>
                    <div class="value" id="po-tax">₹0</div>
                </div>
                <div class="total-item grand">
                    <div class="label">Grand Total</div>
                    <div class="value" id="po-grand">₹0</div>
                </div>
            </div>
        </form>
    </div>
    <div class="slide-panel-footer">
        <button class="btn-ghost btn-cancel">Save as Draft</button>
        <button class="btn-primary" id="create-send-po-btn">Create & Send</button>
    </div>
</div>

@section PageScripts {
    <script src="~/js/procurement.js"></script>
    <script>
        const materials = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Materials));

        function addPoRow() {
            const tbody = document.querySelector('#po-items-table tbody');
            const row = document.createElement('tr');
            row.innerHTML = `
                <td>
                    <select class="form-control material-select" style="height:32px; font-size:12px;">
                        <option value="">Select Material</option>
                        ${materials.map(m => `<option value="${m.Id}" data-unit="${m.Unit}">${m.Name}</option>`).join('')}
                    </select>
                </td>
                <td><input type="number" class="form-control qty-input" value="1" style="height:32px;"></td>
                <td><input type="number" class="form-control rate-input" value="0" style="height:32px;"></td>
                <td><input type="number" class="form-control tax-input" value="18" style="height:32px;"></td>
                <td class="line-total bold" style="font-size:12px;">₹0</td>
                <td><button type="button" class="remove-item-btn" onclick="this.closest('tr').remove(); ProcurementUI.updateTotals('po-items-table', 'po-subtotal', 'po-tax', 'po-grand');"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6m3 0V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg></button></td>
            `;
            tbody.appendChild(row);

            // Bind calculation
            row.querySelectorAll('input').forEach(input => {
                input.addEventListener('input', () => ProcurementUI.updateTotals('po-items-table', 'po-subtotal', 'po-tax', 'po-grand'));
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            addPoRow(); // Add first row by default

            document.getElementById('create-send-po-btn').addEventListener('click', () => {
                const btn = document.getElementById('create-send-po-btn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner"></span> Creating & Sending...';
                
                setTimeout(() => {
                    alert('PO Created! Sending WhatsApp notification to Vendor...');
                    ProcurementUI.closeAllPanels();
                    window.location.reload();
                }, 2000);
            });
        });
    </script>
}
