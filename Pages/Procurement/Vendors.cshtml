@page
@model ColorvisionPaintsERP.Pages.Procurement.VendorsModel
@{
    ViewData["Title"] = "Vendors Management";
    Layout = "_AppShell";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/procurement.css" />
    <style>
        .vendor-materials {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
        }
        .material-pill {
            background: rgba(0, 0, 0, 0.04);
            color: var(--color-text-secondary);
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 10px;
            font-weight: 600;
        }
    </style>
}

<div class="page-container">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Vendors</h1>
            <p class="page-subtitle">Manage raw material suppliers and quality ratings</p>
        </div>
        <button class="btn-primary" onclick="ProcurementUI.openPanel('add-vendor-panel')">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7v14"/></svg>
            Add Vendor
        </button>
    </div>

    <!-- Summary Row -->
    <div class="procurement-summary-row">
        <div class="glass-card summary-card">
            <div class="label">Total Vendors</div>
            <div class="value">@Model.Vendors.Count</div>
        </div>
        <div class="glass-card summary-card">
            <div class="label">Top Rated (5★)</div>
            <div class="value">@Model.Vendors.Count(v => v.QualityRating == 5)</div>
        </div>
        <div class="glass-card summary-card">
            <div class="label">Active Suppliers</div>
            <div class="value">@Model.Vendors.Count(v => v.IsActive)</div>
        </div>
        <div class="glass-card summary-card">
            <div class="label">Average Rating</div>
            <div class="value">@(Model.Vendors.Any() ? Model.Vendors.Average(v => v.QualityRating).ToString("F1") : "0.0") ★</div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card filter-bar">
        <div class="search-group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" placeholder="Search by company, code or city..." id="vendor-search">
        </div>
        <select class="filter-select">
            <option>All Cities</option>
            <option>Mumbai</option>
            <option>Ahmedabad</option>
            <option>Chennai</option>
        </select>
        <select class="filter-select">
            <option>All Ratings</option>
            <option>5 Stars</option>
            <option>4 Stars & Above</option>
        </select>
    </div>

    <!-- Vendors Table -->
    <div class="glass-card table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Vendor Code</th>
                    <th>Company Name</th>
                    <th>Contact Person</th>
                    <th>City/State</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vendor in Model.Vendors)
                {
                    <tr>
                        <td class="bold">@vendor.VendorCode</td>
                        <td>
                            <div class="primary-text">@vendor.CompanyName</div>
                            <div class="secondary-text">@vendor.Email</div>
                        </td>
                        <td>
                            <div class="primary-text">@vendor.ContactPerson</div>
                            <div class="secondary-text">@vendor.Mobile</div>
                        </td>
                        <td>@vendor.City, @vendor.State</td>
                        <td>
                            <div class="star-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="star @(i <= vendor.QualityRating ? "filled" : "")">★</span>
                                }
                            </div>
                        </td>
                        <td>
                            <span class="status-pill @(vendor.IsActive ? "status-received" : "status-draft")">
                                @(vendor.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td style="text-align:right">
                            <div class="actions-cell">
                                <button class="btn-icon" title="Edit"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg></button>
                                <button class="btn-icon" title="Documents"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ADD VENDOR SLIDE PANEL -->
<div class="slide-panel" id="add-vendor-panel">
    <div class="slide-panel-header">
        <h2>Add New Vendor</h2>
        <button class="close-panel-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
    </div>
    <div class="slide-panel-content">
        <form id="vendor-form">
            <div class="panel-section-title">General Information</div>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>Company Name</label>
                    <input type="text" class="form-control" name="CompanyName" required placeholder="Enter company name">
                </div>
                <div class="form-group">
                    <label>Contact Person</label>
                    <input type="text" class="form-control" name="ContactPerson" placeholder="Name">
                </div>
                <div class="form-group">
                    <label>Mobile Number</label>
                    <input type="tel" class="form-control" name="Mobile" placeholder="Phone">
                </div>
                <div class="form-group full-width">
                    <label>Email Address</label>
                    <input type="email" class="form-control" name="Email" placeholder="vendor@example.com">
                </div>
                <div class="form-group">
                    <label>GST Number</label>
                    <input type="text" class="form-control" name="GstNumber" placeholder="27XXXXX...">
                </div>
                <div class="form-group">
                    <label>Payment Terms (Days)</label>
                    <input type="number" class="form-control" name="PaymentTermsDays" value="30">
                </div>
            </div>

            <div class="panel-section-title" style="margin-top:24px">Address & Category</div>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>Address</label>
                    <input type="text" class="form-control" name="Address">
                </div>
                <div class="form-group">
                    <label>City</label>
                    <input type="text" class="form-control" name="City">
                </div>
                <div class="form-group">
                    <label>State</label>
                    <input type="text" class="form-control" name="State">
                </div>
                <div class="form-group full-width">
                    <label>Quality Rating</label>
                    <div class="star-rating" id="vendor-star-picker">
                        <span class="star" data-value="1">★</span>
                        <span class="star" data-value="2">★</span>
                        <span class="star" data-value="3">★</span>
                        <span class="star" data-value="4">★</span>
                        <span class="star" data-value="5">★</span>
                    </div>
                    <input type="hidden" name="QualityRating" id="QualityRatingInput" value="0">
                </div>
            </div>

            <div class="panel-section-title" style="margin-top:24px">MSDS Documents</div>
            <div class="form-group">
                <input type="file" id="msds-upload" style="display:none">
                <label for="msds-upload" style="cursor:pointer; display:flex; align-items:center; gap:8px; width:fit-content; border: 1.5px dashed rgba(0,0,0,0.1); padding: 12px 20px; border-radius: 8px; color: var(--color-accent); font-weight: 600;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    Upload Document
                </label>
            </div>
        </form>
    </div>
    <div class="slide-panel-footer">
        <button class="btn-ghost btn-cancel">Cancel</button>
        <button class="btn-primary" id="save-vendor-btn">Save Vendor</button>
    </div>
</div>

@section PageScripts {
    <script src="~/js/procurement.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Star Picker
            ProcurementUI.initStarPicker('vendor-star-picker', 'QualityRatingInput');

            // Save Vendor (Mock)
            document.getElementById('save-vendor-btn').addEventListener('click', () => {
                const btn = document.getElementById('save-vendor-btn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner"></span> Saving...';
                
                setTimeout(() => {
                    alert('Vendor profile created successfully!');
                    ProcurementUI.closeAllPanels();
                    window.location.reload();
                }, 1500);
            });
        });
    </script>
}
